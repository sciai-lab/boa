#!/usr/bin/env python3
"""
Convert QM9 list files to split.json format.

This script reads the train, validation, and test list files from the data/lists_qm9 
directory and converts them into a single split.json file that can be used by the 
data loaders.
"""

import json
import os
from pathlib import Path


def read_list_file(file_path):
    """Read a list file and return the list of identifiers."""
    with open(file_path, 'r') as f:
        return [int(line.strip().split("_")[1]) for line in f if line.strip()]


def main():
    # Define paths
    script_dir = Path(__file__).parent
    data_dir = script_dir.parent / "data" / "lists_qm9"
    output_file = script_dir.parent / "data" / "pyscf_split.json"
    
    # Check if data directory exists
    if not data_dir.exists():
        print(f"Error: Data directory {data_dir} does not exist!")
        return
    
    # Define the list files
    list_files = {
        "train": data_dir / "list_train",
        "validation": data_dir / "list_validation", 
        "test": data_dir / "list_test"
    }
    
    # Check if all files exist
    for split_name, file_path in list_files.items():
        if not file_path.exists():
            print(f"Error: {split_name} file {file_path} does not exist!")
            return
    
    # Read all list files
    splits = {}
    for split_name, file_path in list_files.items():
        print(f"Reading {split_name} file: {file_path}")
        splits[split_name] = read_list_file(file_path)
        print(f"  Found {len(splits[split_name])} entries")
    
    # Create output directory if it doesn't exist
    output_file.parent.mkdir(parents=True, exist_ok=True)
    
    # Write to JSON file
    print(f"\nWriting split.json to: {output_file}")
    with open(output_file, 'w') as f:
        json.dump(splits, f, indent=2)
    
    print("Conversion completed successfully!")
    print(f"Split summary:")
    print(f"  Train: {len(splits['train'])} samples")
    print(f"  Validation: {len(splits['validation'])} samples")
    print(f"  Test: {len(splits['test'])} samples")
    print(f"  Total: {sum(len(split) for split in splits.values())} samples")


if __name__ == "__main__":
    main()
